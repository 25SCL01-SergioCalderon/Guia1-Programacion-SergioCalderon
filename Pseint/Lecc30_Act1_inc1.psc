Algoritmo Lecc30_Act1_inc1
	
    Definir dias Como Caracter
    Definir indice Como Entero
	
    Dimension dias[7]
	
    dias[1] <- "Lunes"
    dias[2] <- "Martes"
    dias[3] <- "Miércoles"
    dias[4] <- "Jueves"
    dias[5] <- "Viernes"
    dias[6] <- "Sábado"
    dias[7] <- "Domingo"
	
    Escribir "Ingrese el índice del día (1-7): "
    Leer indice
	
    Escribir "El día correspondiente es: ", dias[indice]
	
FinAlgoritmo
